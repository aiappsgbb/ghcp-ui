# BYOK: Azure AI Foundry
AZURE_FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com/openai/v1/
AZURE_FOUNDRY_API_KEY=your-api-key-here
AZURE_FOUNDRY_MODEL=gpt-4.1

# Server
PORT=3001
NODE_ENV=development

# Workspace: Azure Files mount path (set by ACA volume mount in production)
# WORKSPACE_MOUNT_PATH=/data/workspaces

# Workspace: Azure Blob Storage (optional — falls back to local temp dir)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
# AZURE_STORAGE_CONTAINER_NAME=workspaces

# Optional: GitHub Token (if not using BYOK)
# COPILOT_GITHUB_TOKEN=ghp_xxx

# Global MCP Servers (JSON — injected into every Copilot session)
# Keys/tokens in this JSON stay in env vars, never in code.
# Format: {"name": {MCPServerConfig}}
# Example with GitHub MCP + Tavily search:
# MCP_SERVERS_JSON={"github":{"type":"http","url":"https://api.githubcopilot.com/mcp","headers":{"Authorization":"Bearer ghp_xxx"},"tools":["*"]},"tavily":{"type":"http","url":"https://mcp.tavily.com/mcp","headers":{"Authorization":"Bearer tvly_xxx"},"tools":["*"]}}
#
# For azd deployments, set via:
#   azd env set MCP_SERVERS_JSON '{"github":{"type":"http","url":"...","headers":{"Authorization":"Bearer ..."},"tools":["*"]}}'
